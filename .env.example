TIMELY_API_URL=https://api.timelyapp.com/1.1/
TIMELY_API_TIMEOUT=15

# OAuth application credentials (create an app in your Timely account under oauth_applications).
# TIMELY_OAUTH_REDIRECT_URI must match the redirect registered on that app.
# The standard out-of-band value is prefilled below.
TIMELY_OAUTH_CLIENT_ID=
TIMELY_OAUTH_CLIENT_SECRET=
TIMELY_OAUTH_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# Advanced (self-hosted / regional Timely): override the OAuth endpoints.
# TIMELY_OAUTH_AUTHORIZE_URL=
# TIMELY_OAUTH_TOKEN_URL=

# Obtained automatically by `auth:login` and stored in the config file.
# You normally do not set these by hand.
TIMELY_ACCESS_TOKEN=
TIMELY_REFRESH_TOKEN=
TIMELY_TOKEN_EXPIRES_AT=

# Your Timely workspace ID. TIMELY_USER_ID and TIMELY_CREATED_AT are filled automatically by `set:identity`.
TIMELY_ACCOUNT_ID=
TIMELY_USER_ID=
TIMELY_CREATED_AT=

# Start date for the report period (Must be ISO 8601 format: YYYY-MM-DD)
# Precedence: --since comamand option -> TIMELY_SINCE -> TIMELY_CREATED_AT
TIMELY_SINCE=

# Possible table styles:
# default, markdown, borderless, compact, symfony-style-guide, box, box-double
TABLE_STYLE=
