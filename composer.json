{
    "name": "webhubworks/overtimely",
    "description": "A simple CLI tool that interacts with the Timely API to fetch the relevant data and calculate your overtime balance from it.",
    "keywords": ["framework", "laravel", "laravel zero", "console", "cli","timely","overtime"],
    "homepage": "https://webhub.de",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/webhubworks/overtimely/issues",
        "source": "https://github.com/webhubworks/overtimely"
    },
    "authors": [
        {
            "name": "webhub GmbH",
            "email": "systems@webhub.de"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "illuminate/http": "^12.17",
        "intonate/tinker-zero": "^1.2",
        "laravel-zero/framework": "^12.0.2",
        "laravel-zero/phar-updater": "^1.4",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "spatie/laravel-data": "^4.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/overtimely"]
}
