{
    "name": "wehhubworks/timely-overtime-cli",
    "description": "CLI tool to quickly and easily answer a simple question: What's my overtime count?",
    "keywords": ["framework", "laravel", "laravel zero", "console", "cli","timely"],
    "homepage": "https://webhub.de",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/laravel-zero/laravel-zero/issues",
        "source": "https://github.com/laravel-zero/laravel-zero"
    },
    "authors": [
        {
            "name": "webhub GmbH",
            "email": "systems@webhub.de"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/http": "^12.17",
        "laravel-zero/framework": "^12.0.2",
        "spatie/laravel-data": "^4.23"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["overtime"]
}
